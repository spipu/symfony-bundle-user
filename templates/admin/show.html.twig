{% extends 'base.html.twig' %}
{% import '@SpipuUi/macro/buttons.html.twig' as buttons %}

{% set menuCurrentItem="spipu-user-admin" %}

{% block header_title %}{{ parent() }} - {{ 'spipu.user.page.admin.list'|trans() }} - {{ block('main_title') }}{% endblock %}

{% block main_title %}{{ 'spipu.user.page.admin.show'|trans({'%id': showManager.resource.id}) }}{% endblock %}

{% block main_actions %}
    {{ buttons.back(path('spipu_user_admin_list')) }}
    {% if showManager.resource.id != app.user.id %}
        {% if is_granted('ROLE_ADMIN_MANAGE_USER_EDIT') %}
            <form method="post" action="{{ path('spipu_user_admin_reset', {'id': showManager.resource.id}) }}" style="display: inline"><input type="hidden" name="_token" value="{{ csrf_token('reset_user_' ~ showManager.resource.id) }}">{{ buttons.defaultButton(null, 'spipu.user.action.reset', 'primary confirm-action', 'key', null, 'reset the password of') }}</form>
            {% if showManager.resource.active %}
                <form method="post" action="{{ path('spipu_user_admin_disable', {'id': showManager.resource.id}) }}" style="display: inline"><input type="hidden" name="_token" value="{{ csrf_token('disable_user_' ~ showManager.resource.id) }}">{{ buttons.defaultButton(null, 'spipu.user.action.disable', 'warning', 'times') }}</form>
            {% else %}
                <form method="post" action="{{ path('spipu_user_admin_enable', {'id': showManager.resource.id}) }}" style="display: inline"><input type="hidden" name="_token" value="{{ csrf_token('enable_user_' ~ showManager.resource.id) }}">{{ buttons.defaultButton(null, 'spipu.user.action.enable', 'info', 'check') }}</form>
            {% endif %}
        {% endif %}
        {% if is_granted('ROLE_ADMIN_MANAGE_USER_DELETE') %}
            {{ buttons.delete(path('spipu_user_admin_delete', {'id': showManager.resource.id}), 'user_' ~ showManager.resource.id) }}
        {% endif %}
    {% endif %}
{% endblock %}

{% block body %}
    <ul class="nav nav-tabs" role="tablist" id="myTab">
        <li class="nav-item"><a class="nav-link fw-bold active" aria-selected="false" data-bs-toggle="tab" role="tab" id="info-tab" href="#info" aria-controls="info" >{{ 'spipu.user.fieldset.information'|trans }}</a></li>
        {% if showManager.resource.active and roleService.canEditRoles(showManager.resource.roles) %}
            <li class="nav-item"><a class="nav-link fw-bold"        aria-selected="false" data-bs-toggle="tab" role="tab" id="acl-tab"  href="#acl"  aria-controls="services">{{ 'spipu.user.fieldset.acl'|trans }}</a></li>
        {% endif %}
    </ul>
    <div class="tab-content" id="user-tabs">
        <div class="tab-pane fade show active" id="info" role="tabpanel" aria-labelledby="info-tab" >
            <div class="card border-top-0 rounded-0">
                <div class="card-body">
                    {{ renderManager(showManager) }}
                    {% if is_granted('ROLE_ADMIN_MANAGE_USER_EDIT') %}
                        <div class="tab-sub-actions">
                            {{ buttons.edit(path('spipu_user_admin_edit', {'id': showManager.resource.id}), null, null, 'btn-sm') }}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
        {% if showManager.resource.active and roleService.canEditRoles(showManager.resource.roles) %}
        <div class="tab-pane fade show" id="acl" role="tabpanel" aria-labelledby="acl-tab">
            <div class="card border-top-0 rounded-0">
                <div class="card-body">
                    {% include '@SpipuUser/admin/_acl.html.twig' with {
                        roleService: roleService,
                        userRoles: showManager.resource.roles,
                        userId: showManager.resource.id,
                        submitUrl :  path('spipu_user_admin_acl', {id: showManager.resource.id})
                    } %}
                </div>
            </div>
        </div>
        {% endif %}
    </div>
{% endblock %}
